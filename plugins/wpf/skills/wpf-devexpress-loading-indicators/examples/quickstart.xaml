<Window x:Class="MyApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
        Title="DevExpress Loading Indicators Quickstart" Height="500" Width="700">

    <!-- 1. LoadingDecorator — wraps content; IsSplashScreenShown toggles the overlay -->
    <Grid>
        <dx:LoadingDecorator IsSplashScreenShown="{Binding IsLoading}"
                             OwnerLock="LoadingContent">
            <DataGrid AutoGenerateColumns="True"
                      ItemsSource="{Binding Orders}"
                      Margin="4"/>
        </dx:LoadingDecorator>
    </Grid>

</Window>

<!-- ============================================================
     2. WaitIndicator — inline spinner tied to a ViewModel flag
     ============================================================
<Grid>
    <DataGrid ItemsSource="{Binding Orders}"/>
    <dx:WaitIndicator DeferedVisibility="{Binding IsBusy}"
                      Content="Saving…"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
</Grid>

     ============================================================
     3. LoadingDecorator with a custom indicator template
        (override the default WaitIndicator content via SplashScreenTemplate)
     ============================================================
<dx:LoadingDecorator IsSplashScreenShown="{Binding IsLoading}"
                     SplashScreenDataContext="Loading data...">
    <dx:LoadingDecorator.SplashScreenTemplate>
        <DataTemplate>
            <dx:WaitIndicator Content="{Binding}" DeferedVisibility="True">
                <dx:WaitIndicator.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Please wait" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="{Binding}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </dx:WaitIndicator.ContentTemplate>
            </dx:WaitIndicator>
        </DataTemplate>
    </dx:LoadingDecorator.SplashScreenTemplate>
    <ContentControl Content="{Binding MainContent}"/>
</dx:LoadingDecorator>

     ============================================================
     4. SplashScreenManager — see quickstart.cs § 1 and § 2
        (SplashScreenManager is code-only; no XAML element)
     ============================================================
-->
