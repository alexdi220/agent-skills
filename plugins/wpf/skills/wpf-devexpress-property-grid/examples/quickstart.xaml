<Window x:Class="MyApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dxprg="http://schemas.devexpress.com/winfx/2008/xaml/propertygrid"
        xmlns:local="clr-namespace:MyApp"
        Title="DevExpress Property Grid Quickstart" Width="450" Height="500">
    <Window.DataContext>
        <local:Customer/>
    </Window.DataContext>

    <!-- 1. Auto-generate editors for all public properties -->
    <dxprg:PropertyGridControl SelectedObject="{Binding}"
                               PropertyValueChanged="OnPropertyValueChanged"/>

</Window>

