                      ChildrenPath="Employees"
                      DisplayMemberPath="Name"
                      AllowItemSearch="True"/>

     ============================================================
     3. Custom item template
     ============================================================
<dxa:AccordionControl ItemsSource="{Binding EmployeeDepartments}"
                      ChildrenPath="Employees">
    <dxa:AccordionControl.ItemTemplate>
        <DataTemplate>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                <TextBlock Text=" — "/>
                <TextBlock Text="{Binding Position}" Foreground="Gray"/>
            </StackPanel>
        </DataTemplate>
    </dxa:AccordionControl.ItemTemplate>
</dxa:AccordionControl>

     ============================================================
     4. View mode: expanded header only (no collapse)
     ============================================================
<dxa:AccordionControl ItemsSource="{Binding EmployeeDepartments}"
                      ChildrenPath="Employees"
                      DisplayMemberPath="Name"
                      ViewMode="Collapsed"/>
